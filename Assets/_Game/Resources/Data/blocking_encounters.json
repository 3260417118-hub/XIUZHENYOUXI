{
  "encounters": [
    {
      "id": "encounter_day4_thug_saw_sister",
      "triggerDay": 4,
      "npcName": "小混混",
      "title": "小混混拦路",
      "text": "第四日午后，一个吊儿郎当的小混混挡在林昊面前。",
      "blockMoveMessage": "小混混横在前面，嬉皮笑脸地说道：“急什么？话还没说完呢。”",
      "options": [
        { "text": "把妹妹护在身后", "message": "", "setFlags": ["protected_sister_day4"], "startBattleId": "battle_day4_thug", "resolveEncounter": true, "closeOnly": false, "requireFlags": ["rescued_sister"] },
        { "text": "迎上去", "message": "", "setFlags": ["fought_day4_thug"], "startBattleId": "battle_day4_thug", "resolveEncounter": true, "closeOnly": false },
        { "text": "冷声警告他", "message": "你冷冷看着他，体内灵气微微翻涌。小混混脸色一变，嘴上骂骂咧咧，却不敢再靠近。", "setFlags": ["scared_day4_thug", "thug_reported_sister"], "startBattleId": "", "resolveEncounter": true, "closeOnly": false, "minCultivation": 20 },
        { "text": "暂时忍让", "message": "你压下怒火，后退半步。小混混哈哈大笑，转身往村中跑去，似乎准备通风报信。", "setFlags": ["endured_day4_thug", "thug_reported_sister"], "startBattleId": "", "resolveEncounter": true, "closeOnly": false }
      ],
      "resolvedFlags": [],
      "spawnAtPlayerCurrentCell": true
    },
    {
      "id": "encounter_day7_bully_helpers",
      "triggerDay": 7,
      "npcName": "恶霸帮手",
      "title": "恶霸帮手围堵",
      "text": "第七日清晨，两名赵霸天的帮手堵住去路。",
      "blockMoveMessage": "恶霸帮手伸手拦住你：“赵爷的话还没说完，你想去哪？”",
      "options": [
        { "text": "迎战", "message": "", "setFlags": ["fought_day7_bully_helpers"], "startBattleId": "battle_day7_bully_helpers", "resolveEncounter": true, "closeOnly": false },
        { "text": "带妹妹后退", "message": "你想先回到破败小屋护住妹妹，却发现另一名帮手已经堵住退路。", "setFlags": ["tried_to_escape_day7"], "startBattleId": "", "resolveEncounter": false, "closeOnly": false, "requireFlags": ["rescued_sister"] },
        { "text": "以锻体功法震慑", "message": "你催动锻体法门，气血如炉。两个帮手脸色一变，没想到你短短数日已有这般变化，只得放下狠话退去。", "setFlags": ["scared_bully_helpers_day7", "zhao_batian_day21_threat"], "startBattleId": "", "resolveEncounter": true, "closeOnly": false, "requireSkills": ["skill_body_tempering_basic"] },
        { "text": "暂时忍让", "message": "你选择退让。帮手们冷笑离去，临走前扬言赵霸天第二十一日会亲自来取人。", "setFlags": ["endured_day7_bully_helpers", "zhao_batian_day21_threat"], "startBattleId": "", "resolveEncounter": true, "closeOnly": false }
      ],
      "resolvedFlags": [],
      "spawnAtPlayerCurrentCell": true
    },
    {
      "id": "encounter_day13_faction_fight",
      "triggerDay": 13,
      "npcName": "争斗人群",
      "title": "村口争斗",
      "text": "第十三日，村口聚满了人。两伙人马剑拔弩张，一方自称要维持青石村规矩，另一方则斥责赵霸天横行乡里。争吵很快演变成械斗。",
      "blockMoveMessage": "村口两伙人马已经打成一团，你暂时无法离开这片混乱。",
      "options": [
        { "text": "帮助正派一方", "message": "", "setFlags": ["helped_righteous_faction"], "startBattleId": "battle_day13_help_righteous", "resolveEncounter": true, "closeOnly": false },
        { "text": "帮助邪派一方", "message": "", "setFlags": ["helped_evil_faction"], "startBattleId": "battle_day13_help_evil", "resolveEncounter": true, "closeOnly": false },
        { "text": "暂不插手", "message": "你站在人群外，默默看着两方争斗。你意识到，青石村远比表面更混乱。", "setFlags": ["watched_day13_faction_fight"], "startBattleId": "", "resolveEncounter": true, "closeOnly": false }
      ],
      "resolvedFlags": [],
      "spawnAtPlayerCurrentCell": true
    },
    {
      "id": "encounter_day21_zhao_batian",
      "triggerDay": 21,
      "npcName": "赵霸天",
      "title": "赵霸天上门",
      "text": "第二十一日，青石村口尘土飞扬。赵霸天亲自带人而来，脸上带着毫不掩饰的杀意。“小子，我给过你机会。今日，你死，她跟我走。”",
      "blockMoveMessage": "赵霸天的人围住四周，根本不给你离开的机会。",
      "options": [
        { "text": "拔身而战", "message": "", "setFlags": ["fought_zhao_batian"], "startBattleId": "battle_day21_zhao_batian", "resolveEncounter": true, "closeOnly": false },
        { "text": "拿出星辰剑", "message": "星辰剑出鞘，剑光如夜空流星。赵霸天脸色骤变：“你从哪得来的这等兵器？”", "setFlags": ["revealed_star_sword_to_zhao"], "startBattleId": "battle_day21_zhao_batian_weakened", "resolveEncounter": true, "closeOnly": false, "requireItems": ["star_sword"] },
        { "text": "以锻体入门硬抗", "message": "你气血翻涌，双臂筋骨齐鸣，已不再是当初那个任人欺凌的少年。", "setFlags": ["used_body_tempering_against_zhao"], "startBattleId": "battle_day21_zhao_batian", "resolveEncounter": true, "closeOnly": false, "requireSkills": ["skill_body_tempering_basic"] },
        { "text": "求饶", "message": "赵霸天放声大笑：“现在知道怕了？晚了。”", "setFlags": ["begged_zhao_batian"], "startBattleId": "battle_day21_zhao_batian", "resolveEncounter": true, "closeOnly": false }
      ],
      "resolvedFlags": [],
      "spawnAtPlayerCurrentCell": true
    }
  ]
}
