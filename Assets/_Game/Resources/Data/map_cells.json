    { "id": "cliff_bottom", "mapId": "cliff_bottom", "name": "崖底", "x": 0, "y": 0, "description": "你落在一片狭窄的崖底空地上。四周山壁陡峭，云雾在头顶翻涌，几根粗壮藤蔓垂在岩壁之间。", "walkable": true, "npcIds": [], "actionIds": ["return_to_back_mountain_from_cliff_bottom"], "firstEnterEventId": "", "hiddenUntilUnlocked": true },
